---
import { profile } from '../data/profile';
---
<section id="about">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">01 — About</span>
      <h2>From fluid dynamics to language models.</h2>
    </div>
    <div class="about-grid">
      <div class="about-text reveal">
        {profile.about.map((p) => <p>{p}</p>)}
      </div>
      <aside class="about-side reveal card">
        <dl>
          <div><dt>Based in</dt><dd>{profile.location}</dd></div>
          <div><dt>Focus</dt><dd>LLMs · NLP · MLOps</dd></div>
          <div><dt>Currently</dt><dd>ML Engineer @ MYPEGASUS</dd></div>
          <div><dt>Email</dt><dd><a href={profile.links.email}>{profile.email}</a></dd></div>
        </dl>
      </aside>
    </div>
  </div>
</section>

<style>
  .about-grid { display: grid; grid-template-columns: 1.6fr 1fr; gap: 2.5rem; align-items: start; }
  .about-text p { color: var(--text-soft); margin-bottom: 1rem; font-size: 1.06rem; }
  .about-side { padding: 1.5rem; }
  .about-side dl { display: grid; gap: 1rem; }
  .about-side dt { font-family: var(--font-mono); font-size: .72rem; text-transform: uppercase; letter-spacing: .08em; color: var(--text-muted); }
  .about-side dd { font-weight: 600; }
  .about-side a:hover { color: var(--accent); }
  @media (max-width: 760px) { .about-grid { grid-template-columns: 1fr; } }
</style>
