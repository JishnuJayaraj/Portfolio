---
import { profile } from '../data/profile';
---
<section id="about" class="about-section">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">01 — About</span>
      <h2>From fluid dynamics to language models.</h2>
      <p class="note">How a background in computational mechanics became a career in machine learning.</p>
    </div>
    <div class="about-grid">
      <div class="about-text reveal">
        {profile.about.map((p) => <p>{p}</p>)}

        <div class="about-extra">
          <h3 class="block-label">Education</h3>
          <ul class="edu">
            {profile.education.map((e) => (
              <li>
                <span class="edu-degree">{e.degree}</span>
                <span class="edu-meta">{e.school} · {e.period}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <aside class="about-side reveal">
        <div class="profile-card card">
          <img
            class="profile-photo"
            src={profile.photo}
            alt={`${profile.name}, ${profile.role}, at his desk`}
            width="800"
            height="800"
            loading="lazy"
            decoding="async"
          />
          <dl class="profile-facts">
            <div><dt>Based in</dt><dd>{profile.location}</dd></div>
            <div><dt>Focus</dt><dd>LLMs · NLP · MLOps</dd></div>
            <div><dt>Currently</dt><dd>ML Engineer @ MYPEGASUS</dd></div>
            <div><dt>Contact</dt><dd><a href="#contact">Contact form</a></dd></div>
          </dl>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .about-section .container { position: relative; }
  .about-grid { display: grid; grid-template-columns: 1.6fr 1fr; gap: 3rem; align-items: start; }
  .about-text {
    position: relative;
    padding-left: 1.45rem;
  }
  .about-text::before {
    content: '';
    position: absolute;
    left: 0;
    top: .35rem;
    bottom: .4rem;
    width: 2px;
    background: linear-gradient(180deg, var(--link), color-mix(in srgb, var(--aur-3) 70%, transparent), transparent);
    border-radius: 999px;
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 1.1s var(--ease) .15s;
  }
  .about-text.reveal.in::before { transform: scaleY(1); }
  .about-text p {
    color: var(--text-soft);
    margin-bottom: 1rem;
    font-size: 1.06rem;
    opacity: 0;
    transform: translateY(18px);
  }
  .about-text.reveal.in p { animation: about-copy-in .85s var(--ease) forwards; }
  .about-text.reveal.in p:nth-child(1) { animation-delay: .08s; }
  .about-text.reveal.in p:nth-child(2) { animation-delay: .22s; }
  .about-text.reveal.in p:nth-child(3) { animation-delay: .36s; }

  @keyframes about-copy-in {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Education — plain editorial block under the intro */
  .about-extra {
    margin-top: 2.4rem;
    padding-top: 2.2rem;
    border-top: 1px solid var(--border);
    opacity: 0;
    transform: translateY(18px);
  }
  .about-text.reveal.in .about-extra { animation: about-copy-in .85s var(--ease) .5s forwards; }
  .block-label {
    font-family: var(--font-mono); font-size: .72rem; font-weight: 500;
    text-transform: uppercase; letter-spacing: .1em; color: var(--text-muted);
    margin-bottom: 1.1rem;
  }
  .edu { list-style: none; padding: 0; display: grid; gap: 1.1rem; }
  .edu li { display: grid; gap: .2rem; }
  .edu-degree { font-weight: 600; color: var(--text); }
  .edu-meta { font-size: .9rem; color: var(--text-muted); }

  /* Unified profile card — photo + facts as one unit */
  .about-side { position: sticky; top: 6rem; max-width: 340px; margin-left: auto; }
  .profile-card {
    overflow: hidden;
    transform-origin: center top;
  }
  .about-side.reveal.in .profile-card { animation: profile-card-in 1s var(--ease) .12s both; }
  @keyframes profile-card-in {
    from { transform: translateY(18px) rotate(-1.2deg) scale(.985); }
    to { transform: translateY(0) rotate(0) scale(1); }
  }
  .profile-photo {
    width: 100%; height: auto; aspect-ratio: 1 / 1;
    object-fit: cover; object-position: 50% 28%; display: block;
    transition: transform .7s var(--ease), filter .7s ease;
  }
  .profile-card:hover .profile-photo {
    transform: scale(1.045);
    filter: saturate(1.06) contrast(1.02);
  }
  .profile-facts { padding: 1.5rem 1.6rem; display: grid; gap: 1.1rem; }
  .profile-facts > div { display: grid; gap: .25rem; }
  .profile-facts dt {
    font-family: var(--font-mono); font-size: .72rem; text-transform: uppercase;
    letter-spacing: .08em; color: var(--text-muted);
  }
  .profile-facts dd { font-weight: 600; }
  .profile-facts a:hover { color: var(--link); }

  @media (max-width: 760px) {
    .about-grid { grid-template-columns: 1fr; }
    .about-side { position: static; max-width: 340px; margin: 2.4rem auto 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .about-text::before,
    .about-text p,
    .about-extra,
    .profile-card,
    .profile-photo {
      animation: none !important;
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
    .about-text::before { transform: scaleY(1) !important; }
  }
</style>
