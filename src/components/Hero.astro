---
import { profile } from '../data/profile';
---

<header id="top" class="hero">
  <!-- Soft aurora that eases toward the cursor (no 3D, very light) -->
  <div class="hero-aurora" aria-hidden="true">
    <span class="blob b1"></span>
    <span class="blob b2"></span>
    <span class="blob b3"></span>
    <span class="blob b4"></span>
    <span class="cursor-glow"></span>
  </div>
  <div class="hero-grain" aria-hidden="true"></div>

  <div class="container hero-inner">
    <p class="hero-eyebrow reveal">{profile.role} · {profile.location}</p>
    <h1 class="reveal">
      Hi, I'm <span class="name">{profile.name}</span>.
    </h1>
    <p class="hero-tagline reveal">{profile.tagline}</p>
    <p class="hero-sub reveal">
      I build systems that learn — from large language models and retrieval pipelines
      to the infrastructure that runs them.
    </p>

    <div class="hero-actions reveal">
      <a href="#projects" class="btn btn-primary">View my work</a>
      <a href="#contact" class="btn">Get in touch</a>
    </div>

    <div class="hero-socials reveal">
      <a href={profile.links.github} target="_blank" rel="noopener" aria-label="GitHub">GitHub</a>
      <a href={profile.links.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">LinkedIn</a>
      <a href={profile.links.twitter} target="_blank" rel="noopener" aria-label="Twitter / X">Twitter</a>
      <a href={profile.links.email} aria-label="Email">Email</a>
    </div>
  </div>

  <a href="#about" class="scroll-cue" aria-label="Scroll to content">
    <span>Scroll</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
  </a>
</header>

<script is:inline>
  (() => {
    const aurora = document.querySelector('.hero-aurora');
    const cursorGlow = document.querySelector('.cursor-glow');
    const blobs = [...document.querySelectorAll('.blob')].map((blob, index) => ({
      el: blob,
      index,
      phase: index * 1.7,
      speed: [0.42, 0.34, 0.38, 0.29][index] ?? 0.35,
    }));
    if (!aurora || matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let tx = 0.5, ty = 0.4, cx = 0.5, cy = 0.4;
    addEventListener('pointermove', (e) => {
      tx = e.clientX / window.innerWidth;
      ty = e.clientY / window.innerHeight;
    }, { passive: true });

    const tick = (time = 0) => {
      cx += (tx - cx) * 0.05;   // ease toward the pointer
      cy += (ty - cy) * 0.05;
      aurora.style.transform = `translate3d(${((cx - 0.5) * 140).toFixed(2)}px, ${((cy - 0.5) * 96).toFixed(2)}px, 0)`;

      if (cursorGlow) {
        const glowX = (cx - 0.5) * window.innerWidth * 0.92;
        const glowY = (cy - 0.45) * window.innerHeight * 0.78;
        const glowScale = 1 + Math.abs(cx - 0.5) * 0.34 + Math.abs(cy - 0.5) * 0.22;
        cursorGlow.style.transform =
          `translate(-50%, -50%) translate3d(${glowX.toFixed(2)}px, ${glowY.toFixed(2)}px, 0) scale(${glowScale.toFixed(4)})`;
      }

      blobs.forEach(({ el, phase, speed }) => {
        const styles = getComputedStyle(el);
        const px = parseFloat(styles.getPropertyValue('--px')) || 0;
        const py = parseFloat(styles.getPropertyValue('--py')) || 0;
        const seconds = time / 1000;
        const idleX = Math.sin(seconds * speed + phase) * 28;
        const idleY = Math.cos(seconds * speed * 1.13 + phase) * 24;
        const scale = 1 + Math.sin(seconds * speed * 0.8 + phase) * 0.055;
        const x = (cx - 0.5) * px + idleX;
        const y = (cy - 0.5) * py + idleY;
        el.style.transform = `translate3d(${x.toFixed(2)}px, ${y.toFixed(2)}px, 0) scale(${scale.toFixed(4)})`;
      });
      requestAnimationFrame(tick);
    };
    tick();
  })();
</script>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* ── Aurora ─────────────────────────────────────────────────────────── */
  .hero-aurora {
    position: absolute; inset: -10%;
    z-index: 0;
    pointer-events: none;
    --mx: .5;
    --my: .4;
    transform:
      translate3d(
        calc((var(--mx) - .5) * 140px),
        calc((var(--my) - .5) * 96px),
        0
      );
    will-change: transform;
  }
  .blob {
    position: absolute;
    border-radius: 50%;
    opacity: .9;
    mix-blend-mode: multiply;
    filter: blur(28px) saturate(142%);
    transform: translate3d(0, 0, 0);
    will-change: transform;
    background: radial-gradient(circle at 50% 50%, var(--blob-color), transparent var(--fade, 66%));
    /* JS moves the actual painted gradient so the visible colors track the cursor. */
  }
  .cursor-glow {
    position: absolute;
    left: 50%;
    top: 43%;
    width: min(54vw, 680px);
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    opacity: .86;
    filter: blur(30px) saturate(150%);
    mix-blend-mode: multiply;
    background:
      radial-gradient(circle at 36% 34%, color-mix(in srgb, var(--aur-2) 88%, white), transparent 42%),
      radial-gradient(circle at 65% 58%, color-mix(in srgb, var(--aur-3) 85%, white), transparent 48%),
      radial-gradient(circle at 42% 68%, color-mix(in srgb, var(--aur-4) 82%, white), transparent 52%);
    transform: translate(-50%, -50%);
    will-change: transform;
  }
  .b1 {
    width: 31vw; height: 31vw; top: -6%; right: 1%;
    --px: 560px; --py: 390px;
    --blob-color: var(--aur-1);
  }
  .b2 {
    width: 29vw; height: 29vw; top: 13%; right: 21%;
    --px: -500px; --py: 380px;
    --blob-color: var(--aur-2);
  }
  .b3 {
    width: 30vw; height: 30vw; bottom: -8%; right: 30%;
    --px: 420px; --py: -520px;
    --blob-color: var(--aur-3);
    --fade: 68%;
  }
  .b4 {
    width: 27vw; height: 27vw; top: 30%; right: -3%;
    --px: -600px; --py: -350px;
    --blob-color: var(--aur-4);
    --fade: 68%;
  }

  /* keep particles from crowding the headline on the left */
  .hero-grain {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background: linear-gradient(
      102deg,
      color-mix(in srgb, var(--bg) 92%, transparent) 0%,
      color-mix(in srgb, var(--bg) 44%, transparent) 28%,
      transparent 52%
    );
  }

  /* ── Content ────────────────────────────────────────────────────────── */
  .hero-inner { position: relative; z-index: 1; max-width: 820px; padding-top: 4rem; padding-bottom: 4rem; }
  .hero-eyebrow {
    font-size: .82rem; font-weight: 600; letter-spacing: .16em; text-transform: uppercase;
    color: var(--text-muted); margin-bottom: 1.6rem;
  }
  .hero h1 {
    font-size: clamp(2.9rem, 8vw, 5.4rem);
    font-weight: 500;
    letter-spacing: -.04em;
    line-height: 1.0;
  }
  .name { font-weight: 600; }
  .hero-tagline {
    font-size: clamp(1.25rem, 2.6vw, 1.9rem); font-weight: 400;
    margin-top: 1.6rem; color: var(--text);
    letter-spacing: -.02em;
  }
  .hero-sub { font-size: 1.12rem; color: var(--text-soft); margin-top: 1rem; max-width: 40rem; }
  .hero-actions { display: flex; gap: .8rem; margin-top: 2.4rem; flex-wrap: wrap; }
  .hero-socials { display: flex; gap: 1.6rem; margin-top: 2.4rem; }
  .hero-socials a {
    font-size: .9rem; font-weight: 500; color: var(--text-muted);
    border-bottom: 1px solid transparent; transition: color .2s, border-color .2s;
  }
  .hero-socials a:hover { color: var(--text); border-bottom-color: var(--text); }

  .scroll-cue {
    position: absolute; bottom: 1.8rem; left: 50%; transform: translateX(-50%);
    display: inline-flex; align-items: center; gap: .5rem;
    font-size: .72rem; font-weight: 600; letter-spacing: .14em; text-transform: uppercase;
    color: var(--text-muted);
  }
  .scroll-cue svg { animation: bob 2s ease-in-out infinite; }
  @keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(5px); } }

  @media (max-width: 860px) {
    .hero-aurora { inset: -20%; }
    .hero-grain { background: linear-gradient(180deg, color-mix(in srgb, var(--bg) 8%, transparent), var(--bg) 90%); }
    .blob { opacity: .72; filter: blur(26px) saturate(138%); }
    .cursor-glow { width: 86vw; opacity: .76; filter: blur(28px) saturate(145%); }
    .b1 { width: 50vw; height: 50vw; --px: 330px; --py: 230px; }
    .b2 { width: 46vw; height: 46vw; --px: -300px; --py: 230px; }
    .b3 { width: 48vw; height: 48vw; --px: 250px; --py: -320px; }
    .b4 { width: 42vw; height: 42vw; --px: -340px; --py: -210px; }
  }
</style>
